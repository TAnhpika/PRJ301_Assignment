# =============================================
# Copy file này thành .env và điền giá trị thật.
# Không commit file .env lên Git (đã có trong .gitignore).
#
# Chạy app: đặt .env ở thư mục gốc project (cạnh pom.xml/nbproject).
# Nếu chạy Tomcat mà không đọc được .env: thêm VM option:
#   -Denv.file=/đường/dẫn/đầy/đủ/đến/project/.env
# =============================================

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+84xxxxxxxxx

# Google OAuth (Đăng nhập Google)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Database (local hoặc Azure SQL)
# Local: DB_HOST=localhost
# Azure (chia sẻ với bạn bè): DB_HOST=ten-server.database.windows.net
DB_HOST=localhost
DB_PORT=1433
DB_NAME=BenhVien
# --- Chủ project (bạn): dùng sqladmin + mật khẩu Azure của bạn ---
# DB_USERNAME=sqladmin
# DB_PASSWORD=your_azure_password
# --- Bạn bè (khi clone project): dùng tài khoản bạn cấp (vd: sa / 123) ---
DB_USERNAME=sa
DB_PASSWORD=123

# Dùng Azure SQL thì bật Encrypt (mặc định true cho Azure)
# DB_ENCRYPT=true
# DB_TRUST_SERVER_CERTIFICATE=false

# PayOS (Thanh toán)
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Email (Gmail SMTP - dùng App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Cloudflare (nếu dùng)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=

# Google Vision (Face ID) - đường dẫn tuyệt đối tới file JSON service account
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
